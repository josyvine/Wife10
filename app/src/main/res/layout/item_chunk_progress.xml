<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- Active chunk label (e.g. Chunk #1: Compressing) -->
    <TextView
        android:id="@+id/tvChunkLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chunk #1: Processing..."
        android:textSize="12sp"
        android:textColor="@color/editorial_primary_dark"
        android:textStyle="bold" />

    <!-- Chunk-specific linear progress tracker -->
    <ProgressBar
        android:id="@+id/pbChunkPercentage"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:max="100" />

    <!-- Symmetrical speed and size layout for individual concurrent slices -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvChunkSpeedAndSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/editorial_text_secondary"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/tvChunkPercentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="0%"
            android:textSize="11sp"
            android:textColor="@color/editorial_accent"
            android:textStyle="bold" />

    </RelativeLayout>

</LinearLayout>